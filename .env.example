# Database (Vercel Postgres or any Postgres provider)
DATABASE_URL=postgresql://user:password@host:port/dbname

# GitHub OAuth App (create at https://github.com/settings/applications/new)
# Homepage URL: https://shieldcn.dev
# Callback URL: https://shieldcn.dev/api/auth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Optional: a personal GitHub token as fallback when pool is empty
GITHUB_TOKEN=

# Site URL
NEXT_PUBLIC_URL=https://shieldcn.dev
